# Dockerfile para el microservicio de libros

# Imagen base ligera de Node 20
FROM node:20-alpine

# Directorio de trabajo dentro del contenedor
WORKDIR /app

# Copiamos archivos de dependencias y las instalamos
COPY package.json package-lock.json* ./
RUN npm install

# Copiamos el código fuente del servicio de libros
COPY ./service/books ./service/books

# Puerto expuesto para el servicio
EXPOSE 3002

# Comando de inicio del servidor
CMD ["node", "service/books/index.js"]
